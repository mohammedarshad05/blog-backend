{% extends 'base.html.twig' %}

{% block title %}All Blogs{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto py-10 px-6">

    <div class="flex justify-between items-center mb-8">
        <h1 class="text-4xl font-bold">All Blogs</h1>

        <a href="{{ path('app_blog_new') }}"
           class="bg-blue-600 text-white px-5 py-3 rounded-lg hover:bg-blue-700 transition">
            Create Blog
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="mb-6 rounded-lg bg-green-100 border border-green-300 text-green-800 px-4 py-3">
            {{ message }}
        </div>
    {% endfor %}

    {% if blogs is empty %}
        <p class="text-gray-500">No blogs created yet.</p>
    {% else %}
        <div class="grid gap-6">
            {% for blog in blogs %}
                <div class="border rounded-xl p-6 shadow-sm">
                    <h2 class="text-2xl font-bold">
                        <a href="{{ path('show_blog', {'id': blog.id}) }}"
                           class="hover:text-blue-600">
                            {{ blog.title }}
                        </a>
                    </h2>

                    <p class="text-gray-600 mt-2">
                        {{ blog.excerpt }}
                    </p>

                    <p class="text-sm text-gray-400 mt-3">
                        {{ blog.author }} • {{ blog.category }}
                    </p>

                    <div class="flex gap-4 mt-4">
                        <a href="{{ path('blog_edit', {'id': blog.id}) }}"
                           class="text-blue-600 hover:underline">
                            Edit
                        </a>

                        <a href="{{ path('blog_delete', {'id': blog.id}) }}"
                           class="text-red-600 hover:underline">
                            Delete
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}