{{ form_start(form) }}

<div class="space-y-5">
    <div>
        {{ form_label(form.title) }}
        {{ form_widget(form.title, {'attr': {'class': 'w-full border rounded-lg px-4 py-2'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <div>
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug, {'attr': {'class': 'w-full border rounded-lg px-4 py-2'}}) }}
        {{ form_errors(form.slug) }}
    </div>

    <div>
        {{ form_label(form.author) }}
        {{ form_widget(form.author, {'attr': {'class': 'w-full border rounded-lg px-4 py-2'}}) }}
        {{ form_errors(form.author) }}
    </div>

    <div>
        {{ form_label(form.category) }}
        {{ form_widget(form.category, {'attr': {'class': 'w-full border rounded-lg px-4 py-2'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <div>
        {{ form_label(form.featuredImage) }}
        {{ form_widget(form.featuredImage, {'attr': {'class': 'w-full border rounded-lg px-4 py-2'}}) }}
        {{ form_errors(form.featuredImage) }}
    </div>

    <div>
        {{ form_label(form.excerpt) }}
        {{ form_widget(form.excerpt, {'attr': {'class': 'w-full border rounded-lg px-4 py-2 min-h-24'}}) }}
        {{ form_errors(form.excerpt) }}
    </div>

    <div>
        {{ form_label(form.content) }}
        {{ form_widget(form.content, {'attr': {'class': 'w-full border rounded-lg px-4 py-2 min-h-40'}}) }}
        {{ form_errors(form.content) }}
    </div>

    {{ form_row(form.save, {'attr': {'class': 'bg-black text-white px-6 py-3 rounded-lg'}}) }}
</div>

{{ form_end(form) }}